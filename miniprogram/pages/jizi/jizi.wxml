<view class="page">
  <view class="search-bar">
    <view class="input-wrapper">
      <input class="search-input" placeholder="输入汉字（最多200字）..." maxlength="200"
        value="{{inputValue}}" bindinput="onInput" bindconfirm="doSearch" confirm-type="done" />
      <view class="clear-input" wx:if="{{inputValue.length > 0}}" bindtap="clearInput">
        <text>×</text>
      </view>
    </view>
    <view class="search-btn" bindtap="doSearch">
      <text>生成集字</text>
    </view>
  </view>

  <!-- 格线切换 -->
  <view class="grid-style-bar" wx:if="{{cells.length > 0}}">
    <view class="style-btn {{gridStyle === 'fangge' ? 'active' : ''}}" bindtap="switchGridStyle" data-style="fangge">
      <text>方格</text>
    </view>
    <view class="style-btn {{gridStyle === 'hengxian' ? 'active' : ''}}" bindtap="switchGridStyle" data-style="hengxian">
      <text>横线</text>
    </view>
    <view class="style-btn {{gridStyle === 'tianzi' ? 'active' : ''}}" bindtap="switchGridStyle" data-style="tianzi">
      <text>田字格</text>
    </view>
  </view>

  <!-- 集字网格 -->
  <view class="jizi-area" wx:if="{{cells.length > 0}}">
    <view class="jizi-grid grid-{{gridStyle}}">
      <view class="jizi-cell {{item.empty ? 'empty' : ''}} {{item.punct ? 'punct' : ''}}"
        wx:for="{{cells}}" wx:key="index"
        bindtap="onCellTap" data-char="{{item.char}}" data-punct="{{item.punct}}">
        <!-- 田字格十字线 -->
        <view class="tianzi-h" wx:if="{{gridStyle === 'tianzi'}}"></view>
        <view class="tianzi-v" wx:if="{{gridStyle === 'tianzi'}}"></view>
        <text class="cell-text" wx:if="{{!item.empty}}">{{item.char}}</text>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{history.length > 0}}">
    <view class="history-header">
      <text>搜索历史</text>
      <view class="clear-history" bindtap="clearAllHistory">
        <text>清除</text>
      </view>
    </view>
    <view class="history-tags">
      <view class="history-tag" wx:for="{{history}}" wx:key="index"
        bindtap="onHistoryTap" data-text="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- Lightbox -->
  <view class="lightbox" wx:if="{{lightboxVisible}}" bindtap="closeLightbox">
    <view class="lightbox-content" catchtap="">
      <canvas type="2d" id="lightboxCanvas" class="lightbox-canvas"></canvas>
    </view>
  </view>
</view>
