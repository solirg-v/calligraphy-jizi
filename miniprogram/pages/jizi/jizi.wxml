<view class="page">
  <view class="page-header">
    <text class="page-subtitle">输入文字，生成荆霄鹏行楷集字排版</text>
  </view>

  <view class="search-bar">
    <view class="input-wrapper">
      <input class="search-input" placeholder="输入汉字（最多200字）..." maxlength="200"
        value="{{inputValue}}" bindinput="onInput" bindconfirm="doSearch" confirm-type="done" />
      <view class="clear-input" wx:if="{{inputValue.length > 0}}" bindtap="clearInput">
        <text>×</text>
      </view>
    </view>
    <view class="search-btn" bindtap="doSearch">
      <text>生成集字</text>
    </view>
  </view>

  <!-- 格线切换 + 导出 -->
  <view class="grid-style-bar" wx:if="{{cells.length > 0}}">
    <view class="style-btns">
      <view class="style-btn {{gridStyle === 'fangge' ? 'active' : ''}}" bindtap="switchGridStyle" data-style="fangge">
        <text>方格</text>
      </view>
      <view class="style-btn {{gridStyle === 'hengxian' ? 'active' : ''}}" bindtap="switchGridStyle" data-style="hengxian">
        <text>横线</text>
      </view>
      <view class="style-btn {{gridStyle === 'tianzi' ? 'active' : ''}}" bindtap="switchGridStyle" data-style="tianzi">
        <text>田字格</text>
      </view>
    </view>
    <view class="export-btn" bindtap="exportImage">
      <text>导出图片</text>
    </view>
  </view>

  <!-- 字体加载中提示 -->
  <view class="font-loading-tip" wx:if="{{cells.length > 0 && !fontReady}}">
    <text class="loading-text">字体加载中...</text>
  </view>

  <!-- 集字网格 -->
  <view class="jizi-area" wx:if="{{cells.length > 0}}">
    <view class="jizi-grid grid-{{gridStyle}}">
      <view class="jizi-cell {{item.empty ? 'empty' : ''}} {{item.punct ? 'punct' : ''}}"
        wx:for="{{cells}}" wx:key="index"
        bindtap="onCellTap" data-char="{{item.char}}" data-punct="{{item.punct}}">
        <!-- 田字格十字线 -->
        <view class="tianzi-h" wx:if="{{gridStyle === 'tianzi'}}"></view>
        <view class="tianzi-v" wx:if="{{gridStyle === 'tianzi'}}"></view>
        <text class="cell-text {{fontReady ? '' : 'font-loading'}}" wx:if="{{!item.empty}}">{{item.char}}</text>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{history.length > 0}}">
    <view class="history-header">
      <text>搜索历史</text>
      <view class="clear-history" bindtap="clearAllHistory">
        <text>清除</text>
      </view>
    </view>
    <view class="history-tags">
      <view class="history-tag" wx:for="{{history}}" wx:key="index"
        bindtap="onHistoryTap" data-text="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{cells.length === 0 && history.length === 0}}">
    <text class="empty-icon">集</text>
    <text class="empty-text">输入汉字，生成荆霄鹏行楷集字排版</text>
  </view>

  <!-- 底部版权 -->
  <view class="footer">
    <text>荆霄鹏行楷字体仅供教学参考</text>
  </view>

  <!-- Lightbox -->
  <view class="lightbox" wx:if="{{lightboxVisible}}" bindtap="closeLightbox">
    <view class="lightbox-content" catchtap="">
      <image wx:if="{{lightboxImg}}" src="{{lightboxImg}}" mode="aspectFit" class="lightbox-img" />
      <canvas wx:elif="{{lightboxCanvas}}" type="2d" id="lightboxCanvas" class="lightbox-canvas"></canvas>
      <view class="lightbox-actions" wx:if="{{lightboxImg}}">
        <view class="lightbox-save" catchtap="saveToAlbum">
          <text>保存到相册</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Hidden canvas for export -->
  <canvas type="2d" id="exportCanvas" class="export-canvas"></canvas>
</view>
