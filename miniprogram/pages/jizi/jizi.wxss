.page {
  padding: 24rpx 0;
  min-height: 100vh;
}

.jizi-area {
  margin: 0 24rpx 40rpx;
}

/* Grid style switcher */
.grid-style-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin: 0 24rpx 16rpx;
}

.style-btn {
  padding: 8rpx 28rpx;
  font-size: 24rpx;
  color: #999;
  background: #fff;
  border: 1px solid #e0d8d0;
  border-radius: 24rpx;
}

.style-btn.active {
  color: #fff;
  background: #5a4a3a;
  border-color: #5a4a3a;
}

/* Grid base */
.jizi-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 0;
  background: #fff;
  border-radius: 12rpx;
  padding: 6rpx;
  border: 1px solid #e0d8d0;
  overflow: hidden;
}

.jizi-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cell-text {
  font-family: 'JingXiaoPeng', cursive;
  font-size: 58rpx;
  color: #000;
  position: relative;
  z-index: 1;
}

.jizi-cell.punct .cell-text {
  font-family: -apple-system, 'PingFang SC', sans-serif;
  font-size: 40rpx;
  color: #999;
}

/* ===== 方格：实线边框 ===== */
.grid-fangge .jizi-cell {
  background: #faf8f5;
  border: 1px solid #e0d8d0;
}

.grid-fangge .jizi-cell.empty {
  background: #faf8f5;
  border: 1px solid #e0d8d0;
}

/* ===== 横线：只有水平线 ===== */
.grid-hengxian .jizi-cell {
  background: #fff;
  border: none;
  border-bottom: 1px solid #bbb;
}

.grid-hengxian .jizi-cell.empty {
  background: #fff;
  border: none;
  border-bottom: 1px solid #bbb;
}

/* ===== 田字格：浅红边框 + 十字实线 ===== */
.grid-tianzi .jizi-cell {
  background: #fff;
  border: 1px solid #e8a0a0;
}

.grid-tianzi .jizi-cell.empty {
  background: #fff;
  border: 1px solid #e8a0a0;
}

.tianzi-h {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  height: 1px;
  background: #e8a0a0;
  z-index: 0;
}

.tianzi-v {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 1px;
  background: #e8a0a0;
  z-index: 0;
}

/* Lightbox */
.lightbox {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lightbox-content {
  position: relative;
}

.lightbox-canvas {
  width: 600rpx;
  height: 600rpx;
}
