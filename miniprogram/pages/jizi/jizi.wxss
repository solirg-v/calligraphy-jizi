/* Grid style switcher + export */
.grid-style-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 24rpx 24rpx 16rpx;
}

.style-btns {
  display: flex;
  gap: 16rpx;
}

.style-btn {
  padding: 8rpx 28rpx;
  font-size: 24rpx;
  color: #999;
  background: #fff;
  border: 1px solid #e0d8d0;
  border-radius: 24rpx;
}

.style-btn.active {
  color: #fff;
  background: #5a4a3a;
  border-color: #5a4a3a;
}

.export-btn {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #5a4a3a;
  background: #fff;
  border: 1px solid #5a4a3a;
  border-radius: 24rpx;
}

/* Grid base */
.jizi-area {
  margin: 16rpx 24rpx 0;
}

.jizi-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 0;
  background: #fff;
  border-radius: 12rpx;
  padding: 6rpx;
  border: 1px solid #e0d8d0;
  overflow: hidden;
}

.jizi-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cell-text {
  font-family: 'JingXiaoPeng', -apple-system, 'PingFang SC', sans-serif;
  font-size: 58rpx;
  color: #000;
  position: relative;
  z-index: 1;
}

.font-loading-tip {
  text-align: center;
  padding: 16rpx 0;
}

.font-loading-tip .loading-text {
  color: #aaa;
  font-size: 24rpx;
}

.jizi-cell.punct .cell-text {
  font-family: -apple-system, 'PingFang SC', sans-serif;
  font-size: 40rpx;
  color: #999;
}

/* ===== 方格 ===== */
.grid-fangge .jizi-cell {
  background: #fff;
  border: 1px solid #e8a0a0;
}

.grid-fangge .jizi-cell.empty {
  background: #fff;
  border: 1px solid #e8a0a0;
}

/* ===== 横线 ===== */
.grid-hengxian .jizi-cell {
  background: #fff;
  border: none;
  border-bottom: 1px solid #e8a0a0;
}

.grid-hengxian .jizi-cell.empty {
  background: #fff;
  border: none;
  border-bottom: 1px solid #e8a0a0;
}

/* ===== 田字格 ===== */
.grid-tianzi .jizi-cell {
  background: #fff;
  border: 1px solid #e8a0a0;
}

.grid-tianzi .jizi-cell.empty {
  background: #fff;
  border: 1px solid #e8a0a0;
}

.tianzi-h {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  height: 1px;
  background: #e8a0a0;
  z-index: 0;
}

.tianzi-v {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 1px;
  background: #e8a0a0;
  z-index: 0;
}

/* Lightbox */
.lightbox {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lightbox-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lightbox-img {
  max-width: 92vw;
  max-height: 80vh;
}

.lightbox-canvas {
  width: 600rpx;
  height: 600rpx;
  border-radius: 8rpx;
}

.lightbox-actions {
  margin-top: 24rpx;
}

.lightbox-save {
  padding: 16rpx 48rpx;
  background: #5a4a3a;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
}

/* Hidden canvas for export */
.export-canvas {
  position: fixed;
  left: -9999px;
  width: 900px;
  height: 1200px;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e8e0d8;
  color: #5a4a3a;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #bbb;
  font-size: 26rpx;
}

/* ===== Dark mode ===== */
@media (prefers-color-scheme: dark) {
  .style-btn {
    color: #7a7268;
    background: #2a2420;
    border-color: #3a3430;
  }

  .style-btn.active {
    color: #1a1614;
    background: #c0a890;
    border-color: #c0a890;
  }

  .export-btn {
    color: #c0a890;
    background: #2a2420;
    border-color: #c0a890;
  }

  .jizi-grid {
    background: #2a2420;
    border-color: #3a3430;
  }

  .cell-text {
    color: #e8e0d8;
  }

  .font-loading-tip .loading-text {
    color: #6a6258;
  }

  .jizi-cell.punct .cell-text {
    color: #7a7268;
  }

  .grid-fangge .jizi-cell {
    background: #2a2420;
    border-color: #5a3838;
  }

  .grid-fangge .jizi-cell.empty {
    background: #2a2420;
    border-color: #5a3838;
  }

  .grid-hengxian .jizi-cell {
    background: #2a2420;
    border-bottom-color: #5a3838;
  }

  .grid-hengxian .jizi-cell.empty {
    background: #2a2420;
    border-bottom-color: #5a3838;
  }

  .grid-tianzi .jizi-cell {
    background: #2a2420;
    border-color: #5a3838;
  }

  .grid-tianzi .jizi-cell.empty {
    background: #2a2420;
    border-color: #5a3838;
  }

  .tianzi-h {
    background: #5a3838;
  }

  .tianzi-v {
    background: #5a3838;
  }

  .lightbox-save {
    background: #c0a890;
    color: #1a1614;
  }

  .empty-icon {
    background: #3a3430;
    color: #c0a890;
  }

  .empty-text {
    color: #5a5248;
  }
}
