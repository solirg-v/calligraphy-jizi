.auth-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
}

.auth-card {
  width: 100%;
  margin-top: -15vh;
  background: #fff;
  border-radius: 24rpx;
  padding: 64rpx 40rpx;
  text-align: center;
}

.auth-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #5a4a3a;
  margin-bottom: 16rpx;
}

.auth-desc {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.auth-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.auth-input {
  width: 500rpx;
  height: 88rpx;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  text-align: center;
  padding: 0 24rpx;
  border: 2px solid #d4c9be;
  border-radius: 12rpx;
  background: #fff;
}

.auth-verify-btn {
  width: 500rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #5a4a3a;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.auth-verify-btn::after {
  border: none;
}

.auth-loading text {
  color: #aaa;
  font-size: 28rpx;
}

.auth-error {
  display: block;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #c04040;
}

.auth-help {
  margin-top: 48rpx;
}

.auth-help-text {
  font-size: 24rpx;
  color: #bbb;
}

/* ===== Dark mode ===== */
@media (prefers-color-scheme: dark) {
  .auth-card {
    background: #2a2420;
  }

  .auth-title {
    color: #c0a890;
  }

  .auth-desc {
    color: #7a7268;
  }

  .auth-input {
    border-color: #3a3430;
    background: #1a1614;
    color: #e8e0d8;
  }

  .auth-verify-btn {
    background: #c0a890;
    color: #1a1614;
  }

  .auth-loading text {
    color: #6a6258;
  }

  .auth-error {
    color: #d05050;
  }

  .auth-help-text {
    color: #5a5248;
  }
}
