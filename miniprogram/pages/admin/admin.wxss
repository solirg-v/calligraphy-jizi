.admin {
  padding: 32rpx;
  min-height: 100vh;
  background: #f5f0eb;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #999;
  position: relative;
}

.tab-item.active {
  color: #5a4a3a;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #5a4a3a;
  border-radius: 3rpx;
}

.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5a4a3a;
  margin-bottom: 24rpx;
}

/* 生成码 */
.gen-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.gen-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #e0d8d0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.gen-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  background: #5a4a3a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.gen-result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.gen-count {
  font-size: 26rpx;
  color: #999;
}

.copy-all-btn {
  font-size: 26rpx;
  color: #c04040;
  font-weight: 600;
}

.code-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.code-chip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f9f5f0;
  border: 2rpx solid #e0d8d0;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #5a4a3a;
  font-weight: 600;
}

.copy-tag {
  color: #c04040;
  font-size: 22rpx;
  font-weight: 400;
}

/* 筛选 */
.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-btn {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #f5f0eb;
  color: #999;
}

.filter-btn.active {
  background: #5a4a3a;
  color: #fff;
}

/* 码列表 */
.code-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.code-item {
  padding: 20rpx;
  background: #f9f5f0;
  border-radius: 16rpx;
}

.code-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.code-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 2rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.status-available {
  background: #e8f5e9;
  color: #4caf50;
}

.status-distributed {
  background: #fff3e0;
  color: #ff9800;
}

.status-used {
  background: #fce8e8;
  color: #c04040;
}

.code-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 24rpx;
}

.action-link {
  color: #5a4a3a;
  text-decoration: underline;
}

.action-danger {
  color: #c04040;
}

.openid-text {
  color: #999;
  font-size: 20rpx;
  word-break: break-all;
}

/* 学员列表 */
.search-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  border: 2rpx solid #e0d8d0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.search-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  background: #5a4a3a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.student-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.student-item {
  padding: 20rpx;
  background: #f9f5f0;
  border-radius: 16rpx;
}

.student-main {
  margin-bottom: 12rpx;
}

.student-openid {
  display: block;
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
}

.student-code {
  font-size: 24rpx;
  color: #5a4a3a;
  font-weight: 600;
}

.student-no-code {
  font-size: 24rpx;
  color: #bbb;
}

.student-actions {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 48rpx 0;
  color: #bbb;
  font-size: 28rpx;
}

/* 分页 */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-top: 32rpx;
}

.page-btn {
  color: #5a4a3a;
  font-size: 28rpx;
  padding: 8rpx 24rpx;
  border: 2rpx solid #e0d8d0;
  border-radius: 12rpx;
}

.page-info {
  color: #999;
  font-size: 26rpx;
}
