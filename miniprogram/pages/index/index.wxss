.home {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
}

.home-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.home-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #5a4a3a;
  margin-bottom: 16rpx;
}

.home-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.home-cards {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.home-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 40rpx;
  border-radius: 24rpx;
  border: 2px solid #e0d8d0;
  background: #fff;
}

.home-card:active {
  opacity: 0.85;
}

.card-jizi {
  border-color: #c04040;
  background: linear-gradient(135deg, #fff 0%, #fef5f5 100%);
}

.card-zizu {
  border-color: #5a4a3a;
  background: linear-gradient(135deg, #fff 0%, #f9f5f0 100%);
}

.card-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.card-jizi .card-icon {
  background: #fce8e8;
  color: #c04040;
}

.card-zizu .card-icon {
  background: #f0ebe5;
  color: #5a4a3a;
}

.card-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #999;
}

.home-footer {
  margin-top: auto;
  padding-top: 48rpx;
}

.home-footer text {
  color: #bbb;
  font-size: 22rpx;
}
