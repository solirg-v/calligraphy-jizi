.mode-select {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 24rpx;
}

.mode-select-inner {
  text-align: center;
  width: 100%;
  max-width: 640rpx;
  margin-top: -15vh;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #2c2c2c;
  letter-spacing: 0.1em;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  color: #888;
  font-size: 28rpx;
  margin-bottom: 36rpx;
}

.mode-buttons {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.mode-btn {
  background: #fff;
  border: 2px solid #e0d8d0;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  text-align: center;
}

.mode-btn:active {
  border-color: #8b7355;
  background: #faf8f5;
}

.mode-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #5a4a3a;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.mode-title {
  display: block;
  font-size: 32rpx;
  color: #2c2c2c;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.mode-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}
