page {
  background: #f5f0eb;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.page {
  padding: 24rpx 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Page header (subtitle) */
.page-header {
  text-align: center;
  padding: 16rpx 24rpx 8rpx;
  background: #fff;
  border-bottom: 1px solid #e0d8d0;
}

.page-subtitle {
  color: #888;
  font-size: 24rpx;
}

/* Search bar */
.search-bar {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 24rpx 0;
}

.input-wrapper {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  width: 100%;
  font-size: 28rpx;
  padding: 20rpx 60rpx 20rpx 24rpx;
  border: 2px solid #d4c9be;
  border-radius: 12rpx;
  background: #fff;
}

.clear-input {
  position: absolute;
  right: 16rpx;
  background: none;
  border: none;
  color: #bbb;
  font-size: 32rpx;
  padding: 0;
  line-height: 1;
}

.search-btn {
  padding: 20rpx 36rpx;
  font-size: 28rpx;
  background: #5a4a3a;
  color: #fff;
  border: none;
  border-radius: 12rpx;
}

/* History */
.history-section {
  padding: 20rpx 24rpx;
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-header text {
  font-size: 24rpx;
  color: #999;
}

.clear-history {
  background: none;
  border: none;
  color: #bbb;
  font-size: 24rpx;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  padding: 12rpx 20rpx;
  background: #f5f0eb;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

/* Footer */
.footer {
  text-align: center;
  padding: 32rpx 24rpx;
  margin-top: auto;
}

.footer text {
  color: #bbb;
  font-size: 22rpx;
}

/* Shared text styles */
.placeholder-text {
  color: #ccc;
  font-size: 28rpx;
}

.loading-text {
  color: #aaa;
  font-size: 28rpx;
}
